# Model providers (required for the agent and the agent eval; retrieval evals run keyless)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Postgres (docker compose default)
ANVIL_DATABASE_URL=postgresql://anvil:anvil@localhost:5433/anvil

# Langfuse (self-hosted via docker compose --profile observability; leave empty to disable tracing)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Optional overrides
# ANVIL_ANSWER_MODEL=claude-sonnet-5
# ANVIL_CHEAP_MODEL=claude-haiku-4-5
# ANVIL_JUDGE_MODEL=claude-sonnet-5
# ANVIL_REFUSAL_THRESHOLD=0.0
