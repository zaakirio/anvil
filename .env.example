# Generation is provider-agnostic (default Anthropic/Claude). Set the key for whichever
# provider your ANVIL_*_MODEL points at; retrieval evals and the keyless stub run without one.
# Embeddings are OpenAI-or-local: set OPENAI_API_KEY to use text-embedding-3-small,
# otherwise anvil falls back to a local CPU model (all-MiniLM-L6-v2), which CI uses.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GOOGLE_API_KEY=   # for ANVIL_*_MODEL=google_genai:... (needs `uv sync --extra google`)

# Postgres (docker compose default)
ANVIL_DATABASE_URL=postgresql://anvil:anvil@localhost:5433/anvil

# Langfuse (self-hosted via docker compose --profile observability; leave empty to disable tracing)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# flux control plane (optional A2A surface; requires `uv sync --extra a2a`).
# When FLUX_OTLP_ENDPOINT is set, the anvil-a2a server emits OpenTelemetry spans to flux and
# joins any incoming W3C traceparent. Unset = no tracing, base CLI/MCP untouched.
# FLUX_OTLP_ENDPOINT=http://127.0.0.1:3100/v1/traces
# ANVIL_A2A_EMBEDDER=fallback
# ANVIL_A2A_PORT=8790

# Optional overrides. Models are provider-qualified "provider:model" strings; switch
# providers by changing the prefix and setting the matching key, e.g.
# ANVIL_ANSWER_MODEL=openai:gpt-5.4 (with OPENAI_API_KEY) or google_genai:gemini-2.5-pro.
# ANVIL_ANSWER_MODEL=anthropic:claude-sonnet-5
# ANVIL_CHEAP_MODEL=anthropic:claude-haiku-4-5
# ANVIL_JUDGE_MODEL=anthropic:claude-sonnet-5
# ANVIL_REFUSAL_THRESHOLD=0.0
